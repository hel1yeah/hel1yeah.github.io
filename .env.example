# Default locale for the application (used as fallback)
# Note: The app automatically detects browser language on first visit
# and stores user's language preference in cookies
NUXT_PUBLIC_DEFAULT_LOCALE=en

# Fallback locale if translation is not found
NUXT_PUBLIC_FALLBACK_LOCALE=uk

# Supported locales (JSON array format)
NUXT_PUBLIC_SUPPORTED_LOCALES=["en", "uk"]

# Firebase Realtime Database URL for works data
NUXT_PUBLIC_FIREBASE_URL=https://your-project.firebasedatabase.app/works-data.json
